#!/usr/bin/env bash
#? [Dev] Lint and type check all Python files

set -eo pipefail
cd "$(dirname "$0")/../.."

function usage {
    cat<<EOF2
Lint and type check all Python files

Usage: $0
EOF2
}

while :; do
    case $1 in
        -h|--help) usage; exit ;;
        *) break ;;
    esac
    shift
done

SRC_PATHS=(src tests)

uv run ruff format --check "${SRC_PATHS[@]}"
uv run ruff check "${SRC_PATHS[@]}"
uv run mypy "${SRC_PATHS[@]}"
